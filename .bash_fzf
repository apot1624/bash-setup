rgf() {
  local pattern=""
  local extra_opts=()
  local paths=()
  local less_opts=()

  # 遍历所有参数，提取选项、模式、路径
  while [[ $# -gt 0 ]]; do
    local arg="$1"
    if [[ "$arg" =~ ^-[a-zA-Z0-9]{2,}$ ]]; then
      # 组合短选项拆解（如 -sae -> -s -a -e）
      local chars="${arg:1}"
      for (( i=0; i<${#chars}; i++ )); do
        local c="${chars:$i:1}"
        extra_opts+=("-$c")
      done
      shift
    elif [[ "$arg" == -* ]]; then
      # 普通选项（如 --type、-g）
      extra_opts+=("$arg")
      shift
    else
      # 非选项参数
      if [[ -z "$pattern" ]]; then
        # 第一个非选项参数作为模式
        pattern="$arg"
      else
        # 其余非选项参数作为路径
        paths+=("$arg")
      fi
      shift
    fi
  done

  # 检查是否提供了模式
  if [[ -z "$pattern" ]]; then
    echo "Error: missing search pattern" >&2
    return 1
  fi

  # 检查 extra_opts 中是否有 -i，有则 less 加 -I
  for opt in "${extra_opts[@]}"; do
    if [[ "$opt" == "-i" ]]; then
      less_opts=("-I")
      break
    fi
  done

  # 执行搜索：选项 + 模式 + 路径
  rg --vimgrep --color=always "${extra_opts[@]}" "$pattern" "${paths[@]}" | sort -t: -k1,1 -k2,2n | \
    fzf --ansi --delimiter : \
        --preview 'bat --color=always --highlight-line {2} {1}' \
        --preview-window 'up,80%,border-bottom,+{2}' \
        --bind "enter:execute(bat {1} --pager='less -R ${less_opts[@]} +{2} +/\"$pattern\"')" \
        --bind "ctrl-o:execute(nvim {1} +{2})" \
        --bind "ctrl-l:execute(source ~/.bash_vscode && lingma -g {1}:{2})"
}

## 为 lingma 命令启用 fzf 风格的 ** 补全
complete -F _fzf_path_completion -o default -o bashdefault lingma

## 为 x cd 命令启用 fzf 风格的 ** 补全
complete -F _fzf_path_completion -o default -o bashdefault c
